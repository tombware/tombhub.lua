-- Aim delay timer
local aimDelayTimer = 0
local aimDelayActive = false
local lastTargetName = nil
local lastPosition = nil
local lastTime = nil

RunService.RenderStepped:Connect(function(dt)
    local center = getScreenCenter()
    drawFOV(center)

    local targetData = getClosestPlayer()

    -- Auto switch: reset delay if target changed
    if Settings.AutoSwitch and targetData then
        if targetData.name ~= lastTargetName then
            aimDelayTimer = 0
            aimDelayActive = false
            lastTargetName = targetData.name
        end
    end

    -- Arrow
    if targetData and Settings.ShowArrow and Settings.Enabled then
        local screenPos, onScreen = Camera:WorldToViewportPoint(targetData.part.Position)
        if onScreen then
            drawArrow(Vector2.new(screenPos.X, screenPos.Y))
        else
            hideArrow()
        end
    else
        hideArrow()
    end

    -- Health bar + name tag
    if targetData and (Settings.ShowHealthBar or Settings.ShowNameTag) then
        local character = targetData.player.Character
        if character then
            if not healthBillboard or not healthBillboard.Parent then
                createBillboards(character, targetData.name)
            end
            if healthBar and healthLabel and Settings.ShowHealthBar then
                local hp = targetData.humanoid.Health
                local maxHp = targetData.humanoid.MaxHealth
                local pct = math.clamp(hp / maxHp, 0, 1)
                healthBar.Size = UDim2.new(pct, 0, 1, 0)
                healthLabel.Text = math.floor(hp) .. " HP"
                healthBar.BackgroundColor3 = Color3.fromRGB(
                    255 * (1 - pct), 220 * pct, 50
                )
            end
            if nameBillboard then
                nameBillboard.Enabled = Settings.ShowNameTag
            end
            if healthBillboard then
                healthBillboard.Enabled = Settings.ShowHealthBar
            end
        end
    else
        cleanupBillboards()
    end

    if not Settings.Enabled then return end

    local aiming = (Settings.TapToToggle and Settings.AimActive)
        or (not Settings.TapToToggle and (aimHeld
        or (not Settings.MobileMode and UserInputService:IsMouseButtonPressed(Enum.UserInputType.MouseButton2))))

    if not aiming then
        aimDelayTimer = 0
        aimDelayActive = false
        lastPosition = nil
        lastTime = nil
        return
    end

    -- Aim delay
    if Settings.AimDelay > 0 and not aimDelayActive then
        aimDelayTimer = aimDelayTimer + dt
        if aimDelayTimer >= Settings.AimDelay then
            aimDelayActive = true
        else
            return
        end
    else
        aimDelayActive = true
    end

    if not targetData then return end

    local targetPos = targetData.part.Position

    -- Movement prediction
    if Settings.PredictMovement then
        local now = tick()
        if lastPosition and lastTime then
            local velocity = (targetPos - lastPosition) / (now - lastTime)
            targetPos = targetPos + velocity * Settings.PredictionAmount
        end
        lastPosition = targetData.part.Position
        lastTime = tick()
    end

    local _, onScreen = Camera:WorldToViewportPoint(targetPos)
    if not onScreen then return end

    local targetCFrame = CFrame.lookAt(Camera.CFrame.Position, targetPos)
    Camera.CFrame = Camera.CFrame:Lerp(targetCFrame, Settings.Smoothness)
end)

