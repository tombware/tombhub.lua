local function getScreenCenter()
    local vp = Camera.ViewportSize
    return Vector2.new(vp.X / 2, vp.Y / 2)
end

local function getClosestPlayer()
    local closestData = nil
    local shortestDist = Settings.FOV
    local origin = getScreenCenter()

    for _, player in ipairs(Players:GetPlayers()) do
        if player == LocalPlayer then continue end
        local character = player.Character
        if not character then continue end
        local targetPart = character:FindFirstChild(Settings.HitPart)
            or character:FindFirstChild("HumanoidRootPart")
        if not targetPart then continue end
        local humanoid = character:FindFirstChildOfClass("Humanoid")
        if not humanoid or humanoid.Health <= 0 then continue end

        -- Max distance check
        local root = LocalPlayer.Character and LocalPlayer.Character:FindFirstChild("HumanoidRootPart")
        if root then
            local worldDist = (targetPart.Position - root.Position).Magnitude
            if worldDist > Settings.MaxDistance then continue end
        end

        local screenPos, onScreen = Camera:WorldToViewportPoint(targetPart.Position)
        if onScreen then
            local dist = (Vector2.new(screenPos.X, screenPos.Y) - origin).Magnitude
            if dist < shortestDist then
                shortestDist = dist
                closestData = {
                    part = targetPart,
                    player = player,
                    humanoid = humanoid,
                    name = player.Name
                }
            end
        end
    end

    return closestData
end

local function drawArrow(screenPos)
    local center = getScreenCenter()
    local dir = (screenPos - center).Unit
    local arrowTip = center + dir * 60
    local arrowLeft = arrowTip - dir * 14 + Vector2.new(-dir.Y, dir.X) * 8
    local arrowRight = arrowTip - dir * 14 + Vector2.new(dir.Y, -dir.X) * 8

    arrowLine1.From = center + dir * 20
    arrowLine1.To = arrowTip
    arrowLine2.From = arrowTip
    arrowLine2.To = arrowLeft
    arrowLine3.From = arrowTip
    arrowLine3.To = arrowRight

    for _, line in ipairs({arrowLine1, arrowLine2, arrowLine3}) do
        line.Visible = true
    end
end

local function hideArrow()
    for _, line in ipairs({arrowLine1, arrowLine2, arrowLine3}) do
        line.Visible = false
    end
end

local function drawFOV(center)
    local shape = Settings.FOVShape
    fovCircle.Visible = false
    fovSquare.Visible = false
    for _, l in ipairs(diamondLines) do l.Visible = false end

    if not Settings.ShowFOV or not Settings.Enabled then return end

    if shape == "Circle" then
        fovCircle.Position = center
        fovCircle.Visible = true

    elseif shape == "Square" then
        local s = Settings.FOV * 2
        fovSquare.Position = Vector2.new(center.X - Settings.FOV, center.Y - Settings.FOV)
        fovSquare.Size = Vector2.new(s, s)
        fovSquare.Visible = true

    elseif shape == "Diamond" then
        local r = Settings.FOV
        local top    = center + Vector2.new(0, -r)
        local right  = center + Vector2.new(r, 0)
        local bottom = center + Vector2.new(0, r)
        local left   = center + Vector2.new(-r, 0)
        diamondLines[1].From = top;    diamondLines[1].To = right
        diamondLines[2].From = right;  diamondLines[2].To = bottom
        diamondLines[3].From = bottom; diamondLines[3].To = left
        diamondLines[4].From = left;   diamondLines[4].To = top
        for _, l in ipairs(diamondLines) do l.Visible = true end
    end
end

